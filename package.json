{
  "name": "findit",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-only Spot It (Dobble) explainer and custom deck builder.",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "generate:placeholders": "node scripts/generate-placeholders.mjs",
    "build": "node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "test": "node --test --test-isolation=none \"tests/**/*.spec.mjs\"",
    "test:watch": "node --test --watch --test-isolation=none \"tests/**/*.spec.mjs\""
  },
  "dependencies": {
    "canvas": "^3.2.0"
  },
  "engines": {
    "node": ">=20"
  }
}
